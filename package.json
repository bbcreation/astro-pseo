{
  "name": "astro-pseo",
  "version": "2.0.0",
  "description": "Astro integration that generates robots.txt, sitemap.xml, and llms.txt — and imports pSEO campaign archives. Static prerender (default) or SSR.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./config": "./src/config.js",
    "./runtime": "./src/runtime.js",
    "./templates/defaultLayout.astro": "./src/templates/defaultLayout.astro"
  },
  "bin": {
    "astro-pseo": "./bin/astro-pseo.js"
  },
  "files": [
    "src",
    "bin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "seo",
    "sitemap",
    "robots",
    "llms.txt",
    "pseo",
    "programmatic-seo"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbcreation/astro-pseo.git"
  },
  "homepage": "https://github.com/bbcreation/astro-pseo#readme",
  "bugs": {
    "url": "https://github.com/bbcreation/astro-pseo#troubleshooting"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "astro": "^4.16.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
