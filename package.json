    "bin",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "astro",
    "astro-integration",
    "seo",
    "sitemap",
    "robots",
    "llms.txt",
    "pseo",
    "programmatic-seo"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbcreation/astro-pseo.git"
  },
  "homepage": "https://github.com/bbcreation/astro-pseo#readme",
  "bugs": {
    "url": "https://github.com/bbcreation/astro-pseo/issues"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "marked": "^12.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
